AI_FORECAST_APP_NAME=YoloFarm AI Forecast
AI_FORECAST_ENV=development
AI_SERVICE_TOKEN=replace_with_shared_service_token

# Reuse existing MySQL source from main server
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=yolofarm

# Forecast DB (Timescale/PostgreSQL)
TIMESCALE_DSN=postgresql://postgres:postgres@localhost:5432/yolofarm_forecast

# Trained model artifact
MODEL_ARTIFACT_PATH=artifacts/models/gru_latest.pt

# Architecture & Training
HIDDEN_SIZE=64
NUM_LAYERS=2
LOOKBACK=24
LEARNING_RATE=0.001
MAX_EPOCHS=100
EARLY_STOPPING_PATIENCE=10
DROPOUT=0.2

# Inference
MC_DROPOUT_SAMPLES=50
